@page "/"
@page "/products"
@inject SupabaseClientService Supabase
@inject NavigationManager Nav

<MudPaper Class="pa-4 mx-auto" MaxWidth="900px">

    <MudText Typo="Typo.h5" Class="mb-4">商品一覧</MudText>

    <!-- 作品一覧（タップで絞り込み） -->
    <MudChipSet T="int?"
                SelectedValue="@SelectedSeriesId"
                SelectedValueChanged="OnSeriesChanged"
                Mandatory="false" Color="Color.Primary"
                SelectedColor="Color.Secondary"
                Class="mb-4">

        <MudChip Value="@((int?)null)">すべて</MudChip>

        @foreach (var s in AllSeries)
        {
            <MudChip Value="@((int?)s.Id)">@s.Name</MudChip>
        }
    </MudChipSet>

    <!-- 商品一覧切り替えタブ -->
    <MudTabs @bind-ActivePanelIndex="ActiveTab" Class="mb-4">
        <MudTabPanel Text="所持">
            @RenderOwnedTab()
        </MudTabPanel>

        <MudTabPanel Text="欲しい">
            @RenderWantedTab()
        </MudTabPanel>

        <MudTabPanel Text="交換用">
            @RenderTradeTab()
        </MudTabPanel>
    </MudTabs>

    <MudDivider Class="my-4" />

</MudPaper>


@code {
    #region 変数

    List<Series> AllSeries = new();
    int? SelectedSeriesId;
    int ActiveTab = 0;

    List<VariantListItem>? VariantItems;

    #endregion

    #region プロパティ

    /// <summary>所持タブ表示</summary>
    private IEnumerable<VariantListItem> OwnedItems =>
    VariantItems!
        .Where(x => x.Wanted > 0) // 希望数1以上が前提
        .Where(x => x.OwnedForDisplay > 0);

    /// <summary>ほしいものタブ表示</summary>
    private IEnumerable<VariantListItem> WantedItems =>
    VariantItems!
        .Where(x => x.WantedForDisplay != "0");

    /// <summary>交換用タブ表示</summary>
    private IEnumerable<VariantListItem> TradeItems =>
    VariantItems!
        .Where(x => x.TradeForDisplay > 0);

    #endregion

    // ------------------------------
    // 初期化
    // ------------------------------
    protected override async Task OnInitializedAsync()
    {
        await LoadSeries();
        await LoadVariantList();
    }

    private async Task LoadSeries()
    {
        var seriesResult = await Supabase.Client
            .From<Series>()
            .Order(x => x.Name, Ordering.Ascending)
            .Get();

        AllSeries = seriesResult.Models;
    }

    // ------------------------------
    // 排出品中心の一覧データ取得
    // ------------------------------
    private async Task LoadVariantList()
    {
        // 1. 親商品
        var productQuery = Supabase.Client
            .From<Product>()
            .Select("*")
            .Filter("is_template", Operator.Equals, "false");

        var productResult = SelectedSeriesId.HasValue
            ? await productQuery.Filter("series_id", Operator.Equals, SelectedSeriesId.Value).Get()
            : await productQuery.Get();

        var products = productResult.Models;

        if (products.Count == 0)
        {
            VariantItems = new();
            return;
        }

        // 2. 子商品（VariantSource）
        var sourceResult = await Supabase.Client
            .From<VariantSource>()
            .Filter("product_id", Operator.In, products.Select(p => p.Id).ToArray())
            .Get();

        var sources = sourceResult.Models;

        // 3. 排出品（ProductVariant）
        var variantResult = await Supabase.Client
            .From<ProductVariant>()
            .Filter("product_id", Operator.In, products.Select(p => p.Id).ToArray())
            .Order(x => x.OrderIndex, Ordering.Ascending)
            .Get();

        var variants = variantResult.Models;

        // 4. 一覧用 ViewModel に変換
        VariantItems =
            (from v in variants
             join s in sources on v.SourceId equals s.Id into vs
             from s in vs.DefaultIfEmpty()
             join p in products on v.ProductId equals p.Id
             select new VariantListItem
                 {
                     ProductId = p.Id,
                     ProductTitle = p.Title,
                     Category = p.Category,
                     VariantName = v.Name,
                     DisplayName = string.IsNullOrWhiteSpace(v.Name)
                         ? p.Title
                         : $"{p.Title} - {v.Name}",
                     ImageUrl = v.ImageUrl,
                     OrderIndex = v.OrderIndex,
                     SourceOrderIndex = s?.OrderIndex ?? 0,
                     Owned = v.Owned,
                     Wanted = v.Wanted
                 })
            .OrderBy(x => x.Category)
            .ThenBy(x => x.ProductTitle)
            .ThenBy(x => x.SourceOrderIndex)
            .ThenBy(x => x.OrderIndex)
            .ToList();
    }

    private async Task OnSeriesChanged(int? value)
    {
        SelectedSeriesId = value;
        await LoadVariantList();
    }

    #region メソッド

    /// <summary>所持タブ表示</summary>
    private RenderFragment RenderOwnedTab() => __builder =>
    {
        if (OwnedItems == null || !OwnedItems.Any())
        {
            __builder.AddContent(0, "該当するアイテムがありません");
            return;
        }

        // --- カテゴリあり ---
        foreach (var categoryGroup in OwnedItems
            .Where(x => !string.IsNullOrWhiteSpace(x.Category))
            .GroupBy(x => x.Category))
        {
            <MudExpansionPanel Text="@categoryGroup.Key">
                @RenderProductGroups(categoryGroup)
            </MudExpansionPanel>
        }

        // --- カテゴリなし（パネルなしでそのまま表示） ---
        var noCategoryItems = OwnedItems
            .Where(x => string.IsNullOrWhiteSpace(x.Category));

        if (noCategoryItems.Any())
        {
            @RenderProductGroups(noCategoryItems)
        }
    };

    /// <summary>所持タブ表示共通処理</summary>
    RenderFragment RenderProductGroups(IEnumerable<VariantListItem> items) => __builder =>
    {
        foreach (var productGroup in items.GroupBy(x => x.ProductTitle))
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1"
                     Style="border-left:4px solid #90caf9;padding-left:8px;">
                <MudLink Href="@($"products/edit/{productGroup.First().ProductId}")">
                    @productGroup.Key
                </MudLink>
            </MudText>

            @foreach (var item in productGroup.OrderBy(x => x.OrderIndex))
            {
                <div class="d-flex align-center ml-4 mb-2">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;margin-right:8px;" />
                    }

                    <div>
                        @item.VariantName
                        （@item.OwnedForDisplay）
                    </div>
                </div>
            }
        }
    };

    /// <summary>ほしいものタブ表示</summary>
    private RenderFragment RenderWantedTab() => __builder =>
    {
        if (WantedItems == null || !WantedItems.Any())
        {
            __builder.AddContent(0, "該当するアイテムがありません");
            return;
        }

        // --- カテゴリあり ---
        foreach (var categoryGroup in WantedItems
            .Where(x => !string.IsNullOrWhiteSpace(x.Category))
            .GroupBy(x => x.Category))
        {
            <MudExpansionPanel Text="@categoryGroup.Key">
                @RenderWantedProductGroups(categoryGroup)
            </MudExpansionPanel>
        }

        // --- カテゴリなし（パネルなしでそのまま表示） ---
        var noCategoryItems = WantedItems
            .Where(x => string.IsNullOrWhiteSpace(x.Category));

        if (noCategoryItems.Any())
        {
            @RenderWantedProductGroups(noCategoryItems)
        }
    };

    /// <summary>ほしいものタブ表示共通処理</summary>
    RenderFragment RenderWantedProductGroups(IEnumerable<VariantListItem> items) => __builder =>
    {
        foreach (var productGroup in items.GroupBy(x => x.ProductTitle))
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1"
                     Style="border-left:4px solid #ffb74d;padding-left:8px;">
                <MudLink Href="@($"products/edit/{productGroup.First().ProductId}")">
                    @productGroup.Key
                </MudLink>
            </MudText>

            @foreach (var item in productGroup.OrderBy(x => x.SourceOrderIndex).ThenBy(x => x.OrderIndex))
            {
                <div class="d-flex align-center ml-4 mb-2">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;margin-right:8px;" />
                    }

                    <div>
                        @item.VariantName
                        （@item.WantedForDisplay）
                    </div>
                </div>
            }
        }
    };

    /// <summary>交換用タブ表示</summary>
    private RenderFragment RenderTradeTab() => __builder =>
    {
        if (TradeItems == null || !TradeItems.Any())
        {
            __builder.AddContent(0, "該当するアイテムがありません");
            return;
        }

        // --- カテゴリあり ---
        foreach (var categoryGroup in TradeItems
            .Where(x => !string.IsNullOrWhiteSpace(x.Category))
            .GroupBy(x => x.Category))
        {
            <MudExpansionPanel Text="@categoryGroup.Key">
                @RenderTradeProductGroups(categoryGroup)
            </MudExpansionPanel>
        }

        // --- カテゴリなし（パネルなしでそのまま表示） ---
        var noCategoryItems = TradeItems
            .Where(x => string.IsNullOrWhiteSpace(x.Category));

        if (noCategoryItems.Any())
        {
            @RenderTradeProductGroups(noCategoryItems)
        }
    };

    /// <summary>交換用タブ表示共通処理</summary>
    RenderFragment RenderTradeProductGroups(IEnumerable<VariantListItem> items) => __builder =>
    {
        foreach (var productGroup in items.GroupBy(x => x.ProductTitle))
        {
            <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1"
                     Style="border-left:4px solid #81c784;padding-left:8px;">
                <MudLink Href="@($"products/edit/{productGroup.First().ProductId}")">
                    @productGroup.Key
                </MudLink>
            </MudText>

            @foreach (var item in productGroup.OrderBy(x => x.SourceOrderIndex).ThenBy(x => x.OrderIndex))
            {
                <div class="d-flex align-center ml-4 mb-2">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             style="width:48px;height:48px;object-fit:cover;border-radius:4px;margin-right:8px;" />
                    }

                    <div>
                        @item.VariantName
                        （@item.TradeForDisplay）
                    </div>
                </div>
            }
        }
    };

    #endregion

    #region ViewModel

    /// <summary>
    /// 表示用リスト
    /// </summary>
    public class VariantListItem
    {
        public Guid ProductId { get; set; }
        public string ProductTitle { get; set; } = "";
        public string Category { get; set; } = "";
        public string? VariantName { get; set; }
        public string DisplayName { get; set; } = "";

        public int SourceOrderIndex { get; set; }
        public int OrderIndex { get; set; }
        public string? ImageUrl { get; set; }
        // --- 追加 ---
        public int Owned { get; set; }
        public int Wanted { get; set; }

        // 所持タブ用（希望数を上限にする）
        public int OwnedForDisplay =>
            Wanted <= 0 ? 0 :
            Owned < Wanted ? Owned : Wanted;

        // 欲しいタブ用（Wanted - Owned）
        public string WantedForDisplay
        {
            get
            {
                if (Wanted == 9999)
                    return "∞"; // 無限回収

                var diff = Wanted - Owned;
                return diff > 0 ? diff.ToString() : "0";
            }
        }

        // 交換用タブ用（Owned - Wanted）
        public int TradeForDisplay =>
            Owned - Wanted;
    }

    #endregion
}
