@page "/products"
@page "/products/{SeriesId:int}"
@inject SupabaseClientService Supabase
@inject NavigationManager Nav

<MudPaper Class="pa-4 mx-auto" MaxWidth="900px">

    <!-- 商品一覧切り替えタブ -->
    <MudTabs @bind-ActivePanelIndex="ActiveTab" Class="mb-4">
        <MudTabPanel Text="所持">
            @RenderTab(OwnedItems, "owned", "#90caf9")
        </MudTabPanel>

        <MudTabPanel Text="欲しい">
            @RenderTab(WantedItems, "wanted", "#ffb74d")
        </MudTabPanel>

        <MudTabPanel Text="交換用">
            @RenderTab(TradeItems, "trade", "#81c784")
        </MudTabPanel>
    </MudTabs>

    <MudDivider Class="my-4" />

</MudPaper>


@code {
    #region 変数

    List<Series> AllSeries = new();
    int? SelectedSeriesId;
    int ActiveTab = 0;

    string headerTitle = "商品一覧";

    /// <summary>画像生成モードフラグ</summary>
    bool IsImageMode = false;

    List<VariantListItem>? VariantItems;

    #endregion

    #region プロパティ
    [Inject] public LayoutStateService LayoutState { get; set; } = default!;
    [Inject] public ImageGenerateService ImageService { get; set; } = default!;

    [Parameter] public int? SeriesId { get; set; }

    /// <summary>所持タブ表示</summary>
    private IEnumerable<VariantListItem> OwnedItems =>
    VariantItems!
        .Where(x => x.Wanted > 0) // 希望数1以上が前提
        .Where(x => x.OwnedForDisplay > 0);

    /// <summary>ほしいものタブ表示</summary>
    private IEnumerable<VariantListItem> WantedItems =>
    VariantItems!
        .Where(x => x.WantedForDisplay != "0");

    /// <summary>交換用タブ表示</summary>
    private IEnumerable<VariantListItem> TradeItems =>
    VariantItems!
        .Where(x => x.TradeForDisplay > 0);

    #endregion

    // ------------------------------
    // 初期化
    // ------------------------------
    protected override async Task OnInitializedAsync()
    {
        await LoadSeries();

        if (SeriesId.HasValue)
            SelectedSeriesId = SeriesId;

        await LoadVariantList();

        // ★ 作品名を取得
        var selectedSeriesName = SelectedSeriesId.HasValue
            ? AllSeries.FirstOrDefault(s => s.Id == SelectedSeriesId)?.Name
            : null;

        // ★ タイトルを組み立て
        headerTitle = selectedSeriesName is null
            ? "商品一覧"
            : $"商品一覧：{selectedSeriesName}";

        ExitImageMode();
    }

    private async Task LoadSeries()
    {
        var seriesResult = await Supabase.Client
            .From<Series>()
            .Order(x => x.Name, Ordering.Ascending)
            .Get();

        AllSeries = seriesResult.Models;
    }

    // ------------------------------
    // 排出品中心の一覧データ取得
    // ------------------------------
    private async Task LoadVariantList()
    {
        // 1. 親商品
        var productQuery = Supabase.Client
            .From<Product>()
            .Select("*")
            .Filter("is_template", Operator.Equals, "false");

        var productResult = SelectedSeriesId.HasValue
            ? await productQuery.Filter("series_id", Operator.Equals, SelectedSeriesId.Value).Get()
            : await productQuery.Get();

        var products = productResult.Models;

        if (products.Count == 0)
        {
            VariantItems = new();
            return;
        }

        // 2. 子商品（VariantSource）
        var sourceResult = await Supabase.Client
            .From<VariantSource>()
            .Filter("product_id", Operator.In, products.Select(p => p.Id).ToArray())
            .Get();

        var sources = sourceResult.Models;

        // 3. 排出品（ProductVariant）
        var variantResult = await Supabase.Client
            .From<ProductVariant>()
            .Filter("product_id", Operator.In, products.Select(p => p.Id).ToArray())
            .Order(x => x.OrderIndex, Ordering.Ascending)
            .Get();

        var variants = variantResult.Models;

        // 4. 一覧用 ViewModel に変換
        VariantItems =
            (from v in variants
             join s in sources on v.SourceId equals s.Id into vs
             from s in vs.DefaultIfEmpty()
             join p in products on v.ProductId equals p.Id
             select new VariantListItem
                 {
                     ProductId = p.Id,
                     ProductTitle = p.Title,
                     Category = p.Category,
                     ReleaseDate = p.ReleaseDate,
                     ReleaseDateText = p.ReleaseDateText,
                     Price = p.Price,
                     VariantId = v.Id,
                     SourceId = v.SourceId,
                     VariantName = v.Name,
                     DisplayName = string.IsNullOrWhiteSpace(v.Name)
                         ? p.Title
                         : $"{p.Title} - {v.Name}",
                     ImageUrl = v.ImageUrl,
                     OrderIndex = v.OrderIndex,
                     SourceOrderIndex = s?.OrderIndex ?? 0,
                     Owned = v.Owned,
                     Wanted = v.Wanted
                 })
            .OrderBy(x => x.Category)
            .ThenBy(x => x.ReleaseDate.HasValue ? 0 : 1)   // 日付あり → 先
            .ThenBy(x => x.ReleaseDate)                    // 日付昇順
            .ThenBy(x => x.ProductTitle)
            .ThenBy(x => x.SourceOrderIndex)
            .ThenBy(x => x.OrderIndex)
            .ToList();
    }

    private async Task OnSeriesChanged(int? value)
    {
        SelectedSeriesId = value;
        await LoadVariantList();
    }

    #region メソッド

    /// <summary>タブレンダリング共通処理</summary>
    RenderFragment RenderTab(IEnumerable<VariantListItem> items, string mode, string color) => __builder =>
    {
        if (items == null || !items.Any())
        {
            __builder.AddContent(0, "該当するアイテムがありません");
            return;
        }

        foreach (var categoryGroup in items
            .Where(x => !string.IsNullOrWhiteSpace(x.Category))
            .GroupBy(x => x.Category))
        {
            <MudExpansionPanel Text="@categoryGroup.Key">
                @RenderProductGroups(categoryGroup, mode, color)
            </MudExpansionPanel>
        }

        var noCategoryItems = items.Where(x => string.IsNullOrWhiteSpace(x.Category));
        if (noCategoryItems.Any())
        {
            @RenderProductGroups(noCategoryItems, mode, color)
        }
    };

    /// <summary>タブ表示共通処理</summary>
    RenderFragment RenderProductGroups(IEnumerable<VariantListItem> items, string mode, string color) => __builder =>
    {
        foreach (var productGroup in items.GroupBy(x => x.ProductId))
        {
            @if (IsImageMode)
            {
                <MudCheckBox T="bool"
                             @bind-Checked="productGroup.First().IsProductSelected"
                             OnChanged="@( (bool? value) => OnProductChecked(productGroup, value == true) )" />
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           OnClick="@(() => SelectFiltered(productGroup))">
                    全選択
                </MudButton>
            }

            <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1"
                     Style=@($"border-left:4px solid {color};padding-left:8px;")>
                <MudLink Href="@($"products/edit/{productGroup.First().ProductId}")">
                    @productGroup.First().ProductTitle
                </MudLink>

                <!-- ★ 発売日・金額の表示 -->
                <span style="margin-left:8px; color:gray; font-size:0.9em;">
                    @(
                        productGroup.First().ReleaseDate?.ToString("yyyy/MM/dd")
                        ?? productGroup.First().ReleaseDateText
                        ?? ""
                    )
                    @if (productGroup.First().Price.HasValue)
                    {
                        <text> / @productGroup.First().Price.Value.ToString("N0") 円</text>
                    }
                </span>

                <!-- ★　個数編集ボタン -->
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="ml-2"
                           OnClick="@(() => StartGroupEdit(productGroup))">
                    個数編集
                </MudButton>

            </MudText>

            //個数編集
            @if (productGroup.Any(x => x.IsGroupEditing))
            {
                var productId = productGroup.First().ProductId;
                var allItems = VariantItems.Where(x => x.ProductId == productId);

                <MudPaper Class="pa-3 ml-4 mb-2 editing-panel" Elevation="0">
                    @foreach (var item in allItems)
                    {
                        <div class="d-flex align-center mb-2">
                            <div style="width:200px;">@item.VariantName</div>

                            <MudNumericField @bind-Value="item.TempOwned"
                                             Min="0"
                                             Style="width:80px;" />

                            <MudIconButton Icon="@Icons.Material.Filled.Add"
                                           OnClick="@(() => item.TempOwned++)" />

                            <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                           Disabled="@(item.TempOwned == 0)"
                                           OnClick="@(() => item.TempOwned--)" />
                        </div>
                    }

                    <MudStack Row Class="mt-2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   OnClick="@(() => SaveGroupEdit(productGroup))">
                            保存
                        </MudButton>

                        <MudButton Variant="Variant.Text" Color="Color.Secondary"
                                   OnClick="@(() => CancelGroupEdit(productGroup))">
                            キャンセル
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }


            @foreach (var item in productGroup.OrderBy(x => x.SourceOrderIndex).ThenBy(x => x.OrderIndex))
            {
                <div class="d-flex align-center ml-4 mb-2">

                    @if (IsImageMode)
                    {
                        <MudCheckBox T="bool"
                                     @bind-Checked="item.IsSelected" />
                    }

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             class="variant-thumb" />
                    }

                    <div>
                        @item.VariantName
                        （@GetDisplayValue(item, mode)）
                    </div>
                </div>
            }
        }
    };

    void StartGroupEdit(IEnumerable<VariantListItem> group)
    {
        var productId = group.First().ProductId;

        var allItems = VariantItems
            .Where(x => x.ProductId == productId);

        foreach (var item in allItems)
        {
            item.IsGroupEditing = true;
            item.TempOwned = item.Owned;
        }
    }

    async Task SaveGroupEdit(IEnumerable<VariantListItem> group)
    {
        var productId = group.First().ProductId;

        var allItems = VariantItems
            .Where(x => x.ProductId == productId);

        foreach (var item in allItems)
        {
            item.Owned = item.TempOwned;

            await Supabase.Client.From<ProductVariant>().Update(new ProductVariant
            {
                Id = item.VariantId,
                ProductId = item.ProductId,        // ★ 必須
                SourceId = item.SourceId,          // ★ 必須
                Name = item.VariantName,           // ★ 必須
                OrderIndex = item.OrderIndex,      // ★ 必須（NOT NULL の場合）
                Owned = item.Owned,
                Wanted = item.Wanted,
                ImageUrl = item.ImageUrl           // ★ null 許可なら不要
            });

            item.IsGroupEditing = false;
        }
    }

    void CancelGroupEdit(IEnumerable<VariantListItem> group)
    {
        var productId = group.First().ProductId;

        var allItems = VariantItems
            .Where(x => x.ProductId == productId);

        foreach (var item in allItems)
            item.IsGroupEditing = false;
    }

    /// <summary>個数表示</summary>
    private string GetDisplayValue(VariantListItem item, string mode)
    {
        return mode switch
        {
            "owned" => item.OwnedForDisplay.ToString(),
            "wanted" => item.WantedForDisplay,
            "trade" => item.TradeForDisplay.ToString(),
            _ => ""
        };
    }

    /// <summary>画像生成モード</summary>
    void EnterImageMode()
    {
        IsImageMode = true;

        LayoutState.SetState(
            title: "画像生成モード",
            onBack: EventCallback.Factory.Create(this, ExitImageMode),
            onSave: EventCallback.Factory.Create(this, GoToImageGeneratePage),
            leftMode: HeaderLeftMode.Back,
            showSave: true,
            backText: "← 戻る",
            saveText: "OK"
        );
    }

    /// <summary>画像生成モード終了</summary>
    void ExitImageMode()
    {
        IsImageMode = false;

        //★ ヘッダー設定
        LayoutState.SetState(
            title: headerTitle,
            onBack: EventCallback.Factory.Create(this, () => Nav.NavigateTo("series")),
            onSave: EventCallback.Factory.Create(this, EnterImageMode),
            leftMode: HeaderLeftMode.Back,
            showSave: true,
            backText: "← 戻る",
            saveText: "画像生成"
        );
    }

    /// <summary>画像生成画面遷移</summary>
    void GoToImageGeneratePage()
    {
        ImageService.SelectedItems = VariantItems.Where(x => x.IsSelected).ToList();
        Nav.NavigateTo("image-generate");
    }

    /// <summary>親商品チェック</summary>
    void OnProductChecked(IEnumerable<VariantListItem> group, bool isChecked)
    {
        foreach (var v in group)
        {
            v.IsSelected = isChecked; // 個数0含む全排出品
        }
    }

    /// <summary>全選択</summary>
    void SelectFiltered(IEnumerable<VariantListItem> items)
    {
        foreach (var v in items)
            v.IsSelected = true;
    }

    #endregion

    #region ViewModel

    /// <summary>
    /// 表示用リスト
    /// </summary>
    public class VariantListItem
    {
        public Guid ProductId { get; set; }
        public string ProductTitle { get; set; } = "";
        public string Category { get; set; } = "";
        public DateOnly? ReleaseDate { get; set; }
        public string? ReleaseDateText { get; set; }
        public decimal? Price { get; set; }
        public string? VariantName { get; set; }
        public string DisplayName { get; set; } = "";

        public int SourceOrderIndex { get; set; }
        public int OrderIndex { get; set; }
        public string? ImageUrl { get; set; }
        public int Owned { get; set; }
        public int Wanted { get; set; }

        //個数編集用
        public Guid VariantId { get; set; }
        public Guid SourceId { get; set; }
        public bool IsGroupEditing { get; set; } = false;
        public int TempOwned { get; set; }

        //画像編集モード
        public bool IsSelected { get; set; } = false;
        public bool IsProductSelected { get; set; } = false; // 親商品用


        // 所持タブ用（希望数を上限にする）
        public int OwnedForDisplay =>
            Wanted <= 0 ? 0 :
            Owned < Wanted ? Owned : Wanted;

        // 欲しいタブ用（Wanted - Owned）
        public string WantedForDisplay
        {
            get
            {
                if (Wanted == 9999)
                    return "∞"; // 無限回収

                var diff = Wanted - Owned;
                return diff > 0 ? diff.ToString() : "0";
            }
        }

        // 交換用タブ用（Owned - Wanted）
        public int TradeForDisplay =>
            Owned - Wanted;
    }

    #endregion
}
