@page "/products"
@page "/products/{SeriesId:int}"
@inject SupabaseClientService Supabase
@inject NavigationManager Nav

<MudPaper Class="pa-4 mx-auto" MaxWidth="900px">

    <!-- 商品一覧切り替えタブ -->
    <MudTabs @bind-ActivePanelIndex="ActiveTab" Class="mb-4">
        <MudTabPanel Text="所持">
            @RenderUnifiedList(OwnedItems, "owned", "#90caf9")
        </MudTabPanel>

        <MudTabPanel Text="欲しい">
            @RenderUnifiedList(WantedItems, "wanted", "#ffb74d")
        </MudTabPanel>

        <MudTabPanel Text="交換用">
            @RenderUnifiedList(TradeItems, "trade", "#81c784")
        </MudTabPanel>
    </MudTabs>

    <MudDivider Class="my-4" />

</MudPaper>


@code {
    #region 定数

    enum GroupMode { Category, Price, ReleaseDate, None }

    #endregion

    #region 変数

    List<Series> AllSeries = new();
    int? SelectedSeriesId;
    int ActiveTab = 0;

    string headerTitle = "商品一覧";

    GroupMode CurrentGroupMode = GroupMode.Category;
    Dictionary<string, bool> GroupExpanded = new();

    /// <summary>画像生成モードフラグ</summary>
    bool IsImageMode = false;

    List<VariantListItem>? VariantItems;

    #endregion

    #region プロパティ

    [Inject] public LayoutStateService LayoutState { get; set; } = default!;
    [Inject] public ImageGenerateService ImageService { get; set; } = default!;

    [Parameter] public int? SeriesId { get; set; }

    /// <summary>所持タブ表示</summary>
    private IEnumerable<VariantListItem> OwnedItems =>
    VariantItems!
        .Where(x => x.Wanted > 0) // 希望数1以上が前提
        .Where(x => x.OwnedForDisplay > 0);

    /// <summary>ほしいものタブ表示</summary>
    private IEnumerable<VariantListItem> WantedItems =>
    VariantItems!
        .Where(x => x.RemainingForWanted != "0");

    /// <summary>交換用タブ表示</summary>
    private IEnumerable<VariantListItem> TradeItems =>
    VariantItems!
        .Where(x => x.Extra > 0);

    #endregion

    #region メソッド

    /// <summary>タブレンダリング共通処理</summary>
    RenderFragment RenderUnifiedList(IEnumerable<VariantListItem> items, string mode, string color) => __builder =>
    {
        if (items == null || !items.Any())
        {
            __builder.AddContent(0, "該当するアイテムがありません");
            return;
        }

        // グループキーだけを Virtualize に渡す
        var groupKeys = items
            .GroupBy(x => GetGroupLabel(x))
            .Select(g => g.Key)
            .ToList();

        <Virtualize TItem="string"
                    Items="@groupKeys"
                    Context="groupKey">
            <div @key="groupKey">
                @RenderGroupBlock(groupKey, items, mode, color)
            </div>
        </Virtualize>
    };

    /// <summary>タブ表示共通処理(グループ)</summary>
    RenderFragment RenderGroupBlock(string groupKey, IEnumerable<VariantListItem> allItems, string mode, string color) => __builder =>
    {
        var groupItems = allItems.Where(x => GetGroupLabel(x) == groupKey).ToList();

        <MudPaper Class="mt-4 mb-2 pa-0" Elevation="1" Style="border-radius:12px; overflow:hidden;">
            <div class="d-flex align-center"
                 style="padding:12px 16px; cursor:pointer; background:var(--mud-palette-surface);"
                 @onclick="() => ToggleGroup(groupKey)">

                <!-- 左のカラーライン -->
                <div style="width:6px; height:24px; background:@color; border-radius:3px; margin-right:12px;"></div>

                <!-- グループ名 -->
                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                    @groupKey
                </MudText>

                <div style="flex:1;"></div>

                <!-- 開閉アイコン -->
                <MudIcon Icon="@(
                                 IsGroupExpanded(groupKey)
                                     ? Icons.Material.Filled.ExpandLess
                                     : Icons.Material.Filled.ExpandMore
                    )" />
            </div>

            <MudCollapse Expanded="@IsGroupExpanded(groupKey)">
                <div style="padding:8px 4px 12px 4px;">
                    @foreach (var item in groupItems)
                    {
                        @RenderProductBlock(item, groupItems, mode, color)
                    }
                </div>
            </MudCollapse>
        </MudPaper>
    };


    /// <summary>タブ表示共通処理(商品)</summary>
    RenderFragment RenderProductBlock(VariantListItem item, IEnumerable<VariantListItem> groupItems, string mode, string color) => __builder =>
    {
        if (IsFirstProductItemInGroup(item, groupItems))
        {
            @RenderProductHeader(item, mode, color)
            ;

            if (item.IsGroupEditing)
            {
                var productGroup = VariantItems!.Where(x => x.ProductId == item.ProductId);
                @RenderEditPanel(productGroup)
                ;
            }
        }

        @RenderVariantRow(item, mode)
    ;
    };

    /// <summary>商品ヘッダー</summary>
    RenderFragment RenderProductHeader(VariantListItem item, string mode, string color) => __builder =>
    {
        <MudText Typo="Typo.subtitle2" Class="mt-2 mb-1"
                 Style=@($"border-left:4px solid {color};")>

            <div class="product-header d-flex align-center"
                 style="width:100%; justify-content:space-between; padding-right:20px; margin-left:12px;">

                <!-- 左：チェックボックス -->
                <div style="flex:0 0 auto; width:@(IsImageMode ? "40px" : "0px"); display:flex; justify-content:center;">
                    @if (IsImageMode)
                    {
                        <MudCheckBox T="bool"
                                     @bind-Checked="item.IsProductSelected"
                                     OnChanged="@( (bool? value) => OnProductChecked(GetProductGroup(item.ProductId), value == true) )" />
                    }
                </div>

                <!-- 中央：商品名・日付 -->
                <div style="flex:1 1 auto; display:flex; flex-direction:column; min-width:0px; margin-right:8px;">
                    <MudLink Href="@($"products/edit/{item.ProductId}")"
                             style="font-size:1.0em; font-weight:600;">
                        @item.ProductTitle
                    </MudLink>

                    <span style="font-size:0.8em; color:gray; margin-top:2px;">
                        @(item.ReleaseDateText 
                            ?? item.ReleaseDate?.ToString("yyyy/MM/dd") 
                            ?? "")
                    </span>
                </div>

                <!-- 右：全選択・価格・個数編集 -->
                <div style="width:60px; text-align:right; display:flex; flex-direction:column; line-height:1.2;">
                    @if (IsImageMode)
                    {
                        <MudButton Variant="Variant.Text" Color="Color.Primary"
                                   Style="padding:0; justify-content:flex-end;"
                                   OnClick="@(() => SelectFiltered(GetProductGroup(item.ProductId)))">
                            全選択
                        </MudButton>
                    }

                    <div style="font-size:0.85em; color:gray;">
                        @if (item.Price.HasValue)
                        {
                            <text>@item.Price.Value.ToString("N0") 円</text>
                        }
                    </div>

                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                               Style="padding:0; justify-content:flex-end;"
                               OnClick="@(() => StartGroupEdit(GetProductGroup(item.ProductId)))">
                        個数編集
                    </MudButton>
                </div>
            </div>
        </MudText>
    };

    /// <summary>個数編集パネル</summary>
    RenderFragment RenderEditPanel(IEnumerable<VariantListItem> group) => __builder =>
    {
        <MudPaper Class="pa-3 ml-4 mb-2 editing-panel"
                  Elevation="0"
                  Style="max-height:400px; overflow-y:auto;">
            @foreach (var v in group)
            {
                <div class="d-flex align-center mb-2"
                     style="justify-content:space-between; width:100%; flex-wrap:nowrap;">

                    <div style="flex:1 1 auto; min-width:140px; max-width:calc(100% - 160px); word-break:break-word; margin-right:8px;">
                        @v.VariantName
                    </div>

                    <div style="width:160px; display:flex; flex-direction:column; font-size:0.85em; line-height:1.2;">

                        <!-- 所持 -->
                        <div class="d-flex align-center" style="justify-content:space-between;">
                            <span>所持：</span>
                            <div class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               Disabled="@(v.TempOwned == 0)"
                                               OnClick="@(() => v.TempOwned--)" />

                                <MudNumericField @bind-Value="v.TempOwned"
                                                 Min="0"
                                                 Dense="true"
                                                 HideSpinButtons="true"
                                                 Size="Size.Small"
                                                 Style="width:40px; font-size:0.8rem; padding:0; margin:0 4px;" />

                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               OnClick="@(() => v.TempOwned++)" />
                            </div>
                        </div>

                        <!-- 未収納 -->
                        <div class="d-flex align-center" style="justify-content:space-between; margin-top:4px;">
                            <span>未収納：</span>
                            <div class="d-flex align-center">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               Disabled="@(v.TempFloating == 0)"
                                               OnClick="@(() => v.TempFloating--)" />

                                <MudNumericField @bind-Value="v.TempFloating"
                                                 Min="0"
                                                 Dense="true"
                                                 HideSpinButtons="true"
                                                 Size="Size.Small"
                                                 Style="width:40px; font-size:0.8rem; padding:0; margin:0 4px;" />

                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Size="Size.Small"
                                               Variant="Variant.Text"
                                               OnClick="@(() => v.TempFloating++)" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            <MudStack Row Class="mt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@(() => SaveGroupEdit(group))">
                    保存
                </MudButton>

                <MudButton Variant="Variant.Text" Color="Color.Secondary"
                           OnClick="@(() => CancelGroupEdit(group))">
                    キャンセル
                </MudButton>
            </MudStack>
        </MudPaper>
    };

    /// <summary>排出品行</summary>
    RenderFragment RenderVariantRow(VariantListItem item, string mode) => __builder =>
    {
        <div class="d-flex align-center ml-4 mb-2"
             style="width:100%; min-height:48px; justify-content:space-between; padding-right:20px;">

            <div class="d-flex align-center"
                 style="flex:1 1 auto; min-width:0px; margin-right:8px; word-break:break-word;">

                <!-- 画像枠（固定） -->
                <div style="width:48px; height:48px; position:relative; margin-right:8px;">

                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl"
                             loading="lazy"
                             style="width:48px; height:48px; object-fit:contain;" />
                    }

                    @if (IsImageMode)
                    {
                        <!-- 選択モード時のオーバーレイ -->
                        <div style="
                            position:absolute;
                            top:0; left:0;
                            width:48px; height:48px;
                            background:rgba(255,255,255,0.5);
                            display:flex;
                            align-items:center;
                            justify-content:center;
                            ">
                            <MudIconButton Icon="@(item.IsSelected
                                                ? Icons.Material.Filled.CheckCircle
                                            : Icons.Material.Outlined.RadioButtonUnchecked)"
                                           Color="Color.Primary"
                                           Size="Size.Medium"
                                           OnClick="@(() => item.IsSelected = !item.IsSelected)" />
                        </div>
                    }
                </div>
                <div style="flex:1;">
                    @item.VariantName

                    @{
                        string lineStyle;

                        if (item.CharacterColors.Count == 1)
                        {
                            // 1人 → 単色ライン
                            lineStyle = $"background:{item.CharacterColors[0]};";
                        }
                        else if (item.CharacterColors.Count > 1)
                        {
                            // 複数人 → グラデーション
                            var colors = string.Join(",", item.CharacterColors);
                            lineStyle = $"background: linear-gradient(to right, {colors});";
                        }
                        else
                        {
                            // キャラなし → ライン非表示
                            lineStyle = "background:transparent;";
                        }
                    }

                    <div style="margin-top:4px; height:4px; border-radius:2px; @lineStyle"></div>
                </div>
            </div>

            <div style="width:80px; text-align:right; display:flex; flex-direction:column; line-height:1.2;">
                @if (mode == "owned")
                {
                    <div style="font-size:0.95em; font-weight:500;">
                        所持：@item.OwnedForDisplay
                    </div>

                    @if (item.UnstoredForDisplay > 0)
                    {
                        <div style="font-size:0.75em; color:#888; margin-top:2px;">
                            未収納：@item.UnstoredForDisplay
                        </div>
                    }
                }
                @if (mode == "wanted")
                {
                    <div style="font-size:0.95em; font-weight:500;">
                        残り：@item.RemainingForWanted
                    </div>

                    @if (item.OwnedForWantedTab > 0)
                    {
                        <div style="font-size:0.75em; color:#888; margin-top:2px;">
                            所持：@item.OwnedForWantedTab
                        </div>
                    }
                }
                @if (mode == "trade")
                {
                    <div style="font-size:0.95em; font-weight:500;">
                        在庫：@item.Extra
                    </div>

                    @if (item.HandExtra != item.Extra)
                    {
                        <div style="font-size:0.75em; color:#888; margin-top:2px;">
                            手元：@item.HandExtra
                        </div>
                    }
                }
            </div>
        </div>
    };


    /// <summary>グループ判定</summary>
    bool IsGroupHeader(VariantListItem item)
    {
        switch (CurrentGroupMode)
        {
            case GroupMode.Category:
                return IsFirstOfGroup(item, x => x.Category);

            case GroupMode.Price:
                return IsFirstOfGroup(item, x => x.Price);

            case GroupMode.ReleaseDate:
                return IsFirstOfGroup(item, x => x.ReleaseDate);

            case GroupMode.None:
                return false;
        }
        return false;
    }

    bool IsFirstOfGroup<T>(VariantListItem item, Func<VariantListItem, T> keySelector)
    {
        var key = keySelector(item);
        return VariantItems!.FirstOrDefault(x => EqualityComparer<T>.Default.Equals(keySelector(x), key)) == item;
    }

    /// <summary>グループラベル表示</summary>
    string GetGroupLabel(VariantListItem item)
    {
        return CurrentGroupMode switch
        {
            GroupMode.Category => string.IsNullOrWhiteSpace(item.Category) ? "未分類" : item.Category,
            GroupMode.Price => item.Price?.ToString("N0") + "円" ?? "価格なし",
            GroupMode.ReleaseDate => item.ReleaseDate?.ToString("yyyy/MM/dd") ?? item.ReleaseDateText ?? "日付なし",
            _ => ""
        };
    }

    void ToggleGroup(string key)
    {
        GroupExpanded[key] = !IsGroupExpanded(key);
    }

    bool IsGroupExpanded(string key)
    {
        return GroupExpanded.ContainsKey(key) && GroupExpanded[key];
    }

    bool IsFirstProductItemInGroup(VariantListItem item, IEnumerable<VariantListItem> groupItems)
    {
        return groupItems.FirstOrDefault(x => x.ProductId == item.ProductId) == item;
    }

    IEnumerable<VariantListItem> GetProductGroup(Guid productId)
        => VariantItems!.Where(x => x.ProductId == productId);

    /// <summary>個数編集開始</summary>
    void StartGroupEdit(IEnumerable<VariantListItem> group)
    {
        var productId = group.First().ProductId;

        foreach (var item in VariantItems!.Where(x => x.ProductId == productId))
        {
            item.IsGroupEditing = true;
            item.TempOwned = item.Owned;
            item.TempFloating = item.Floating;
        }
    }

    /// <summary>個数編集決定</summary>
    async Task SaveGroupEdit(IEnumerable<VariantListItem> group)
    {
        var productId = group.First().ProductId;

        foreach (var item in VariantItems!.Where(x => x.ProductId == productId))
        {
            item.Owned = item.TempOwned;
            item.Floating = item.TempFloating;

            await Supabase.Client.From<ProductVariant>().Update(new ProductVariant
            {
                Id = item.VariantId,
                ProductId = item.ProductId,
                SourceId = item.SourceId,
                Name = item.VariantName,
                OrderIndex = item.OrderIndex,
                Owned = item.Owned,
                Floating = item.Floating,
                Wanted = item.Wanted,
                ImageUrl = item.ImageUrl
            });

            item.IsGroupEditing = false;
        }
    }

    /// <summary>個数編集キャンセル</summary>
    void CancelGroupEdit(IEnumerable<VariantListItem> group)
    {
        var productId = group.First().ProductId;

        foreach (var item in VariantItems!.Where(x => x.ProductId == productId))
            item.IsGroupEditing = false;
    }

    /// <summary>選択モード開始</summary>
    void EnterSelectMode()
    {
        IsImageMode = true;

        LayoutState.SetState(
            title: "選択",
            onBack: EventCallback.Factory.Create(this, ExitSelectMode),
            onSave: EventCallback.Factory.Create(this, GoToImageGeneratePage),
            leftMode: HeaderLeftMode.Back,
            showSave: true,
            backText: "← 戻る",
            saveText: "OK"
        );
    }

    /// <summary>選択モード終了</summary>
    void ExitSelectMode()
    {
        IsImageMode = false;

        LayoutState.SetState(
            title: headerTitle,
            onBack: EventCallback.Factory.Create(this, () => Nav.NavigateTo("series")),
            onSave: EventCallback.Factory.Create(this, EnterSelectMode),
            leftMode: HeaderLeftMode.Back,
            showSave: true,
            backText: "← 戻る",
            saveText: "選択"
        );
    }

    /// <summary>画像生成画面遷移</summary>
    void GoToImageGeneratePage()
    {
        ImageService.SelectedItems = VariantItems!.Where(x => x.IsSelected).ToList();
        Nav.NavigateTo("image-generate");
    }

    /// <summary>親商品選択</summary>
    void OnProductChecked(IEnumerable<VariantListItem> group, bool isChecked)
    {
        foreach (var v in group)
            v.IsSelected = isChecked;
    }

    /// <summary>全選択</summary>
    void SelectFiltered(IEnumerable<VariantListItem> items)
    {
        foreach (var v in items)
            v.IsSelected = true;
    }
    #endregion

    // ------------------------------
    // 初期化
    // ------------------------------
    protected override async Task OnInitializedAsync()
    {
        await LoadSeries();

        if (SeriesId.HasValue)
            SelectedSeriesId = SeriesId;

        await LoadVariantList();

        // ★ 作品名を取得
        var selectedSeriesName = SelectedSeriesId.HasValue
            ? AllSeries.FirstOrDefault(s => s.Id == SelectedSeriesId)?.Name
            : null;

        // ★ タイトルを組み立て
        headerTitle = selectedSeriesName is null
            ? "商品一覧"
            : $"商品一覧：{selectedSeriesName}";

        ExitSelectMode();
    }

    private async Task LoadSeries()
    {
        var seriesResult = await Supabase.Client
            .From<Series>()
            .Order(x => x.Name, Ordering.Ascending)
            .Get();

        AllSeries = seriesResult.Models;
    }

    /// <summary>一覧データ取得</summary>
    /// <returns></returns>
    private async Task LoadVariantList()
    {
        // 1. 親商品
        var productQuery = Supabase.Client
            .From<Product>()
            .Select("*")
            .Filter("is_template", Operator.Equals, "false");

        var productResult = SelectedSeriesId.HasValue
            ? await productQuery.Filter("series_id", Operator.Equals, SelectedSeriesId.Value).Get()
            : await productQuery.Get();

        var products = productResult.Models;

        if (products.Count == 0)
        {
            VariantItems = new();
            return;
        }

        var productIds = products.Select(p => p.Id.ToString()).ToList();

        // ------------------------------
        // 2. 子商品（VariantSource）を IN バッチで取得
        // ------------------------------
        var sources = new List<VariantSource>();

        foreach (var batch in Batch(productIds, 10)) // ← 10 件ずつ
        {
            var result = await Supabase.Client
                .From<VariantSource>()
                .Filter("product_id", Operator.In, batch.ToArray())
                .Get();

            sources.AddRange(result.Models);
        }

        // ------------------------------
        // 3. 排出品（ProductVariant）も IN バッチで取得
        // ------------------------------
        var variants = new List<ProductVariant>();

        foreach (var batch in Batch(productIds, 10))
        {
            var result = await Supabase.Client
                .From<ProductVariant>()
                .Filter("product_id", Operator.In, batch.ToArray())
                .Order(x => x.OrderIndex, Ordering.Ascending)
                .Get();

            variants.AddRange(result.Models);
        }

        // 4.1 キャラ紐付け
        var variantIds = variants.Select(v => v.Id.ToString()).ToList();

        var pvChars = new List<ProductVariantCharacter>();
        foreach (var batch in Batch(variantIds, 10))
        {
            var result = await Supabase.Client
                .From<ProductVariantCharacter>()
                .Filter("product_variant_id", Operator.In, batch.ToArray())
                .Get();

            pvChars.AddRange(result.Models);
        }

        // 4.2 キャラ一覧
        var charactersResult = await Supabase.Client
            .From<Character>()
            .Select("*")
            .Get();

        var characters = charactersResult.Models.ToDictionary(c => c.Id);

        // ------------------------------
        // 4. ViewModel 変換
        // ------------------------------
        VariantItems =
            (from v in variants
             join s in sources on v.SourceId equals s.Id into vs
             from s in vs.DefaultIfEmpty()
             join p in products on v.ProductId equals p.Id
             select new VariantListItem
             {
                 ProductId = p.Id,
                 ProductTitle = p.Title,
                 Category = p.Category,
                 ReleaseDate = p.ReleaseDate,
                 ReleaseDateText = p.ReleaseDateText,
                 Price = p.Price,
                 VariantId = v.Id,
                 SourceId = v.SourceId,
                 VariantName = v.Name,
                 DisplayName = string.IsNullOrWhiteSpace(v.Name)
                     ? p.Title
                     : $"{p.Title} - {v.Name}",
                 ImageUrl = v.ImageUrl,
                 CharacterColors = pvChars
                    .Where(pc => pc.ProductVariantId == v.Id)
                    .OrderBy(pc => characters[pc.CharacterId].OrderIndex)
                    .Select(pc => characters[pc.CharacterId].Color!)
                    .ToList(),
                 OrderIndex = v.OrderIndex,
                 SourceOrderIndex = s?.OrderIndex ?? 0,
                 Owned = v.Owned,
                 Floating = v.Floating,
                 Wanted = v.Wanted
             })
            .OrderBy(x => x.Category)
            .ThenBy(x => x.ReleaseDate.HasValue ? 0 : 1)
            .ThenBy(x => x.ReleaseDate)
            .ThenBy(x => x.ProductTitle)
            .ThenBy(x => x.SourceOrderIndex)
            .ThenBy(x => x.OrderIndex)
            .ToList();

        GroupExpanded.Clear();
    }

    /// <summary>バッチ分割ヘルパー</summary>
    /// <typeparam name="T"></typeparam>
    /// <param name="source"></param>
    /// <param name="size"></param>
    /// <returns></returns>
    private static IEnumerable<List<T>> Batch<T>(IEnumerable<T> source, int size)
    {
        var batch = new List<T>(size);
        foreach (var item in source)
        {
            batch.Add(item);
            if (batch.Count == size)
            {
                yield return batch;
                batch = new List<T>(size);
            }
        }
        if (batch.Count > 0)
            yield return batch;
    }


    private async Task OnSeriesChanged(int? value)
    {
        SelectedSeriesId = value;
        await LoadVariantList();
    }

    #region ViewModel

    /// <summary>
    /// 表示用リスト
    /// </summary>
    public class VariantListItem
    {
        public Guid ProductId { get; set; }
        public string ProductTitle { get; set; } = "";
        public string Category { get; set; } = "";
        public DateOnly? ReleaseDate { get; set; }
        public string? ReleaseDateText { get; set; }
        public decimal? Price { get; set; }
        public string? VariantName { get; set; }
        public string DisplayName { get; set; } = "";

        public int SourceOrderIndex { get; set; }
        public int OrderIndex { get; set; }
        public string? ImageUrl { get; set; }
        public int Owned { get; set; }
        public int Floating { get; set; }
        public int Wanted { get; set; }

        public List<string> CharacterColors { get; set; } = new();

        //個数編集用
        public Guid VariantId { get; set; }
        public Guid SourceId { get; set; }
        public bool IsGroupEditing { get; set; } = false;
        public int TempOwned { get; set; }
        public int TempFloating { get; set; }

        //画像編集モード
        public bool IsSelected { get; set; } = false;
        public bool IsProductSelected { get; set; } = false; // 親商品用

        public int OwnedCapped => Math.Min(Wanted, Owned);
        // 所持タブ
        public int OwnedForDisplay => Math.Max(0, OwnedCapped);
        public int UnstoredForDisplay => Math.Min(OwnedCapped, Floating);
        // 欲しいタブ
        public int OwnedForWantedTab => OwnedCapped;
        public string RemainingForWanted =>
            Wanted == 9999 ? "∞" : Math.Max(0, Wanted - Owned).ToString();
        // 交換用タブ
        public int Extra => Math.Max(0, Owned - Wanted);
        public int HandExtra => Math.Max(0, Owned - Math.Max(Wanted, Floating));
    }

    public class GroupBlock
    {
        public string Label { get; set; } = "";
        public List<VariantListItem> Items { get; set; } = new();
    }

    #endregion
}
