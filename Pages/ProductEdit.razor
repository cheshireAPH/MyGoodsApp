@page "/products/new"
@page "/products/new/{templateId:guid}"
@page "/products/edit/{id:guid}"
@page "/templates/new"
@page "/templates/edit/{id:guid}"
@inject SupabaseClientService Supabase
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject HttpClient Http


<MudPaper Class="pa-4 mx-auto" MaxWidth="900px" Elevation="4">

    <MudText Typo="Typo.h5" Class="mb-4">
        @(IsTemplateMode
            ? (IsEditMode ? "テンプレを編集" : "新規テンプレ作成")
            : (IsEditMode ? "商品を編集" : "新規商品追加"))
    </MudText>

    <!-- 親商品 -->
    <MudTextField @bind-Value="product.Title"
                  Label="@(IsTemplateMode ? "テンプレ名" : "商品名")"
                  Required="true" />

    <MudAutocomplete T="Series"
                     Label="作品名"
                     Value="SelectedSeries"
                     ValueChanged="OnSeriesChanged"
                     ToStringFunc="s => s?.Name"
                     SearchFunc="SearchSeries"
                     Clearable="true"
                     Dense="true" />

    <MudTextField @bind-Value="product.Category" Label="カテゴリ" />

    <MudDivider Class="my-4" />

    <!-- 子商品リスト -->
    @for (var i = 0; i < sources.Count; i++)
    {
        var s = sources[i];

        <MudPaper Class="pa-4 mb-4" Style="border-left:4px solid #90caf9;">

            <!-- 子商品の上下移動 -->
            <div class="d-flex mb-2">
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                               Disabled="@(i == 0)"
                               OnClick="@(() => MoveSourceUp(i))" />

                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                               Disabled="@(i == sources.Count - 1)"
                               OnClick="@(() => MoveSourceDown(i))" />
            </div>

            <!-- パック名 -->
            <MudTextField @bind-Value="s.Source.Name" Label="パック名" />
            @if (!IsTemplateMode)
            {
                <div class="url-with-icon">
                    <MudTextField @bind-Value="s.Source.Url" Label="URL" />

                    <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                   Disabled="@string.IsNullOrWhiteSpace(s.Source.Url)"
                                   OnClick="@(() => OpenUrl(s.Source.Url))"
                                   Color="MudBlazor.Color.Primary"
                                   Size="MudBlazor.Size.Small" />

                    <MudIconButton Icon="@Icons.Material.Filled.ImageSearch"
                                   OnClick="@(() => FetchImageFromUrl(s))"
                                    Color="MudBlazor.Color.Primary"
                                    Size="MudBlazor.Size.Small" />
                </div>
            }

            <MudDivider Class="my-2" />

            <!-- 封入品グリッド -->
            <MudTable Dense="true" Hover="true" Bordered="true" Items="@s.Variants">
                <HeaderContent>
                    @if (!IsTemplateMode)
                    {
                        <MudTh>画像</MudTh>
                    }
                    <MudTh>名前</MudTh>
                    <MudTh>キャラ</MudTh>
                    @if (!IsTemplateMode)
                    {
                        <MudTh>所持</MudTh>
                    }
                    <MudTh>希望</MudTh>
                    <MudTh>順番</MudTh>
                    <MudTh>削除</MudTh>
                </HeaderContent>

                <RowTemplate>
                    @{
                        var variant = context;
                        var rowIndex = s.Variants.IndexOf(variant);
                    }

                    @if (!IsTemplateMode)
                    {
                        <MudTd>
                            <div class="variant-image-cell">
                                @if (!string.IsNullOrWhiteSpace(context.ImageUrl))
                                {
                                    <img src="@context.ImageUrl"
                                         style="width:100px;height:100px;object-fit:cover;border-radius:4px;" />
                                }

                                <MudFileUpload T="IBrowserFile"
                                               OnFilesChanged="@(async e => await OnImageSelected(e, context))"
                                               Accept="image/*"
                                               Variant="Variant.Outlined"
                                               Dense="true"
                                               Style="max-width:120px;" />

                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="MudBlazor.Color.Primary"
                                               Size="MudBlazor.Size.Small"
                                               OnClick="@(() => OpenEditDialog(context))" />

                            </div>
                        </MudTd>
                    }

                    <MudTd>
                        <MudTextField @bind-Value="context.Name" />
                    </MudTd>

                    <MudTd>
                        <MudSelect T="int"
                                   SelectedValues="context.CharacterIds"
                                   SelectedValuesChanged="@(ids => context.CharacterIds = ids.ToHashSet())"
                                   MultiSelection="true"
                                   Dense="true"
                                   ToStringFunc="id => CharacterCandidates.FirstOrDefault(c => c.Id == id)?.Name ?? id.ToString()">
                            @foreach (var c in CharacterCandidates)
                            {
                                <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                            }
                        </MudSelect>

                        <!-- ★ 新規キャラ追加欄（復活） -->
                        <MudTextField @bind-Value="NewCharacterName"
                                      Placeholder="新規キャラ名を追加"
                                      OnBlur="@(() => AddNewCharacter(variant))" />
                    </MudTd>

                    <MudTd Class="variant-count-cell">
                        <div class="count-wrapper">
                            @if (!IsTemplateMode)
                            {
                                <MudNumericField @bind-Value="context.Owned" Min="0" Label="所持数" />
                            }
                            <MudNumericField @bind-Value="context.Wanted" Min="0" Label="希望数" />
                        </div>
                    </MudTd>

                    <MudTd Class="variant-actions-cell">
                        <div class="actions-wrapper">
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                           Disabled="@(rowIndex == 0)"
                                           OnClick="@(() => MoveVariantUp(s, rowIndex))" />

                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                           Disabled="@(rowIndex == s.Variants.Count - 1)"
                                           OnClick="@(() => MoveVariantDown(s, rowIndex))" />

                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="MudBlazor.Color.Error"
                                           Disabled="@(s.Variants.Count == 1)"
                                           OnClick="@(() => RemoveVariant(s, context))" />
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- 封入品追加 -->
            <MudButton Class="mt-2"
                       Variant="Variant.Outlined"
                       Color="MudBlazor.Color.Secondary"
                       OnClick="@(() => AddVariant(s))">
                ＋ 封入品追加
            </MudButton>

            <MudDivider Class="my-2" />

            <!-- 子商品削除 -->
            <MudButton Variant="Variant.Text"
                       Color="MudBlazor.Color.Error"
                       Disabled="@(sources.Count == 1)"
                       OnClick="@(() => RemoveSource(s))">
                子商品削除
            </MudButton>

        </MudPaper>
    }

    <MudButton Variant="Variant.Outlined"
               Color="MudBlazor.Color.Primary"
               OnClick="AddSource">
        ＋ 子商品追加
    </MudButton>

    <MudDivider Class="my-4" />

    <MudButton Variant="Variant.Filled"
               Color="MudBlazor.Color.Primary"
               OnClick="SaveAll">
        @(IsEditMode ? "変更を保存" : "すべて保存する")
    </MudButton>

    <MudButton Variant="Variant.Text"
               Color="MudBlazor.Color.Secondary"
               OnClick="@(() => GoBack())">
        ← 戻る
    </MudButton>

</MudPaper>

@code {
    #region 変数

    Product product = new();
    List<VariantSourceViewModel> sources = new();
    Series? SelectedSeries;
    List<Series> AllSeries = new();
    List<Character> CharacterCandidates = new();
    string NewCharacterName = "";

    #endregion

    #region プロパティ

    [Parameter] public Guid? Id { get; set; }
    [Parameter] public Guid? TemplateId { get; set; }

    private bool IsEditMode => Id.HasValue;
    private bool IsTemplateMode => Nav.Uri.Contains("templates/");

    #endregion

    /* ------------------------------
    SearchSeries
   ------------------------------ */
    private Task<IEnumerable<Series>> SearchSeries(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return Task.FromResult(AllSeries.AsEnumerable());

        return Task.FromResult(
            AllSeries.Where(s => s.Name.Contains(value, StringComparison.OrdinalIgnoreCase))
        );
    }

    /* ------------------------------
    初期化
       ------------------------------ */
    protected override async Task OnInitializedAsync()
    {
        var seriesResult = await Supabase.Client
            .From<Series>()
            .Select("*")
            .Order(x => x.Name, Ordering.Ascending)
            .Get();

        AllSeries = seriesResult.Models;

        if (IsEditMode)
        {
            product = await Supabase.Client
                .From<Product>()
                .Where(x => x.Id == Id.Value)
                .Single();

            SelectedSeries = AllSeries.FirstOrDefault(s => s.Id == product.SeriesId);

            if (SelectedSeries != null)
            {
                var result = await Supabase.Client
                    .From<Character>()
                    .Select("*")
                    .Filter(x => x.SeriesId, Operator.Equals, SelectedSeries.Id)
                    .Order(x => x.Name, Ordering.Ascending)
                    .Get();

                CharacterCandidates = result.Models;
            }

            sources = await LoadSources(product.Id);
        }
        else
        {
            product = new Product();

            if (TemplateId.HasValue)
            {
                // ------------------------------
                // テンプレ本体を読み込む
                // ------------------------------
                var template = await Supabase.Client
                    .From<Product>()
                    .Where(x => x.Id == TemplateId.Value)
                    .Single();

                // 親商品のコピー（商品名は空にする）
                product.SeriesId = template.SeriesId;
                product.Category = template.Category;
                product.IsTemplate = false; // 商品なので false
                product.Title = "";         // 新規商品名は空欄

                // 作品名の選択状態を反映
                SelectedSeries = AllSeries.FirstOrDefault(s => s.Id == product.SeriesId);
                if (SelectedSeries != null)
                    await OnSeriesChanged(SelectedSeries);
                // ------------------------------
                // 子商品・封入品をテンプレからコピー
                // ------------------------------
                sources = await LoadSources(template.Id);

                // コピーした ID を全部リセット（新規商品として保存するため）
                foreach (var s in sources)
                {
                    s.Source.Id = Guid.Empty; // 新規 Insert 扱い

                    foreach (var v in s.Variants)
                    {
                        v.Id = null;          // 新規 Insert 扱い
                        v.Owned = 0;          // 所持数は 0 に初期化
                        // Wanted はテンプレの値を残す（紗香さんの希望）
                    }
                }
            }
            else
            {
                // 通常の新規作成
                sources = new()
        {
            new VariantSourceViewModel
            {
                Variants = new() { new ProductVariantViewModel() }
            }
        };
            }
        }
    }

    /* ------------------------------
    子商品・封入品読み込み
       ------------------------------ */
    private async Task<List<VariantSourceViewModel>> LoadSources(Guid productId)
    {
        var sourcesResult = await Supabase.Client
            .From<VariantSource>()
            .Where(x => x.ProductId == productId)
            .Order(x => x.OrderIndex, Ordering.Ascending)
            .Get();

        var vmList = new List<VariantSourceViewModel>();

        foreach (var s in sourcesResult.Models)
        {
            var vm = new VariantSourceViewModel { Source = s };

            var variantsResult = await Supabase.Client
                .From<ProductVariant>()
                .Where(x => x.SourceId == s.Id)
                .Order(x => x.OrderIndex, Ordering.Ascending)
                .Get();

            foreach (var v in variantsResult.Models)
            {
                var vvm = new ProductVariantViewModel
                {
                    Id = v.Id,
                    Name = v.Name,
                    OrderIndex = v.OrderIndex,
                    ImageUrl = v.ImageUrl,
                    Owned = v.Owned,
                    Wanted = v.Wanted,
                    CharacterIds = new HashSet<int>()
                };

                var charsResult = await Supabase.Client
                    .From<ProductVariantCharacter>()
                    .Where(x => x.ProductVariantId == v.Id)
                    .Get();

                vvm.CharacterIds = charsResult.Models
                    .Select(x => x.CharacterId)
                    .ToHashSet();

                vm.Variants.Add(vvm);
            }

            vmList.Add(vm);
        }

        return vmList;
    }

    /* ------------------------------
    UI 操作
       ------------------------------ */
    private async Task AddNewCharacter(ProductVariantViewModel v)
    {
        if (string.IsNullOrWhiteSpace(NewCharacterName) || SelectedSeries == null)
            return;

        var newChar = new Character
        {
            Name = NewCharacterName,
            SeriesId = SelectedSeries.Id
        };

        var result = await Supabase.Client.From<Character>().Insert(newChar);
        var saved = result.Models.First();

        // キャラ一覧に追加
        CharacterCandidates.Add(saved);

        // 今追加したキャラを選択状態にする
        v.CharacterIds.Add(saved.Id);

        // 入力欄クリア
        NewCharacterName = "";
    }

    void AddSource() =>
    sources.Add(new VariantSourceViewModel { Variants = new() { new ProductVariantViewModel() } });

    void RemoveSource(VariantSourceViewModel s)
    {
        if (sources.Count > 1)
            sources.Remove(s);
    }

    void AddVariant(VariantSourceViewModel s) =>
        s.Variants.Add(new ProductVariantViewModel());

    void RemoveVariant(VariantSourceViewModel s, ProductVariantViewModel v)
    {
        if (s.Variants.Count > 1)
            s.Variants.Remove(v);
    }

    void MoveVariantUp(VariantSourceViewModel s, int index)
    {
        if (index == 0) return;
        var item = s.Variants[index];
        s.Variants.RemoveAt(index);
        s.Variants.Insert(index - 1, item);
    }

    void MoveVariantDown(VariantSourceViewModel s, int index)
    {
        if (index == s.Variants.Count - 1) return;
        var item = s.Variants[index];
        s.Variants.RemoveAt(index);
        s.Variants.Insert(index + 1, item);
    }

    void MoveSourceUp(int index)
    {
        if (index == 0) return;
        var item = sources[index];
        sources.RemoveAt(index);
        sources.Insert(index - 1, item);
    }

    void MoveSourceDown(int index)
    {
        if (index == sources.Count - 1) return;
        var item = sources[index];
        sources.RemoveAt(index);
        sources.Insert(index + 1, item);
    }

    async Task OpenEditDialog(ProductVariantViewModel variant)
    {
        var parameters = new DialogParameters
        {
            ["Variant"] = variant
        };

        var options = new DialogOptions
        {
            FullScreen = true,
            CloseButton = true,
        };

        await DialogService.ShowAsync<ImageEditDialog>("画像編集", parameters, options);
    }


    async Task OpenUrl(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url))
            await JS.InvokeVoidAsync("openUrl", url);
    }

    async Task FetchImageFromUrl(VariantSourceViewModel s)
    {
        if (string.IsNullOrWhiteSpace(s.Source.Url))
            return;

        var imageUrl = ConvertToImageUrl(s.Source.Url);
        if (imageUrl == null)
            return;

        var response = await Http.PostAsJsonAsync(
            "https://localhost:7127/api/ImageProxy",
            new { url = imageUrl }
        );

        var bytes = await response.Content.ReadAsByteArrayAsync();

        // ★ 子商品に属する全ての Variant に画像を設定
        foreach (var variant in s.Variants)
        {
            variant.TempImageBytes = bytes;
            variant.ImageUrl = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
        }
    }

    #region サイト別画像取得

    string ConvertToImageUrl(string url)
    {
        if (url.Contains("movic.jp"))
            return ConvertMovic(url);

        // if (url.Contains("animate-onlineshop.jp"))
        //     return ConvertAnimate(url);

        // if (url.Contains("suruga-ya.jp"))
        //     return ConvertSurugaya(url);

        // 変換できない場合は null
        return null;
    }

    string ConvertMovic(string url)
    {
        // g/ の後ろのコードを取得（先頭の g を含む場合がある）
        var match = Regex.Match(url, @"g/([A-Za-z0-9\-]+)/?$");
        if (!match.Success) return null;

        var code = match.Groups[1].Value;

        // 先頭に g が付いていたら削除
        if (code.StartsWith("g"))
            code = code.Substring(1);

        return $"https://d38cuxvdcwawa4.cloudfront.net/img/goods/L/{code}-l.jpg";
    }

    # endregion

    void GoBack()
    {
        if (IsTemplateMode)
            Nav.NavigateTo("templates");
        else
            Nav.NavigateTo("products");
    }

    /* ------------------------------
    作品変更 → キャラ一覧更新
       ------------------------------ */
    private async Task OnSeriesChanged(Series value)
    {
        SelectedSeries = value;

        if (SelectedSeries == null)
        {
            CharacterCandidates = new();
            return;
        }

        product.SeriesId = SelectedSeries.Id;

        var result = await Supabase.Client
            .From<Character>()
            .Select("*")
            .Filter(x => x.SeriesId, Operator.Equals, SelectedSeries.Id)
            .Order(x => x.Name, Ordering.Ascending)
            .Get();

        CharacterCandidates = result.Models;
    }

    #region 保存

    /// <summary>保存処理</summary>
    /// <returns></returns>
    private async Task SaveAll()
    {
        product.IsTemplate = IsTemplateMode;

        // 自動採番
        for (int i = 0; i < sources.Count; i++)
            sources[i].Source.OrderIndex = i;

        foreach (var s in sources)
            for (int i = 0; i < s.Variants.Count; i++)
                s.Variants[i].OrderIndex = i;

        // 親商品保存
        if (product.Id == Guid.Empty)
        {
            var result = await Supabase.Client.From<Product>().Insert(product);
            product = result.Models.First();
        }
        else
        {
            await Supabase.Client.From<Product>().Update(product);
        }

        // 子商品削除判定
        var existingSources = await Supabase.Client
            .From<VariantSource>()
            .Where(x => x.ProductId == product.Id)
            .Get();

        var existingSourceIds = existingSources.Models.Select(x => x.Id).ToHashSet();
        var currentSourceIds = sources
            .Where(s => s.Source.Id != Guid.Empty)
            .Select(s => s.Source.Id)
            .ToHashSet();

        foreach (var delId in existingSourceIds.Except(currentSourceIds))
        {
            await Supabase.Client
                .From<VariantSource>()
                .Where(x => x.Id == delId)
                .Delete();
        }

        // 子商品 Insert/Update
        foreach (var vm in sources)
        {
            VariantSource savedSource;

            if (vm.Source.Id == Guid.Empty)
            {
                vm.Source.ProductId = product.Id;
                var sResult = await Supabase.Client.From<VariantSource>().Insert(vm.Source);
                savedSource = sResult.Models.First();
                vm.Source.Id = savedSource.Id;
            }
            else
            {
                await Supabase.Client.From<VariantSource>().Update(vm.Source);
                savedSource = vm.Source;
            }

            // まず全 Variant を Insert/Update する前に画像アップロードを済ませる
            foreach (var v in vm.Variants)
            {
                if (v.TempImageBytes != null)
                {
                    var bucket = Supabase.Client.Storage.From("variants");
                    var fileName = $"{v.Id ?? Guid.NewGuid()}.png";

                    // 既存削除
                    await bucket.Remove(fileName);

                    // アップロード
                    await bucket.Upload(v.TempImageBytes, fileName);

                    // URL セット
                    v.ImageUrl = bucket.GetPublicUrl(fileName);

                    // 一時データクリア
                    v.TempImageBytes = null;
                }
            }

            // Insert/Update（画像URLも含めて1回で保存）
            foreach (var v in vm.Variants)
            {
                ProductVariant savedVariant;

                if (!v.Id.HasValue)
                {
                    var insertVariant = new ProductVariant
                    {
                        ProductId = product.Id,
                        SourceId = savedSource.Id,
                        Name = v.Name,
                        OrderIndex = v.OrderIndex,
                        Owned = IsTemplateMode ? 0 : v.Owned,
                        Wanted = v.Wanted,
                        ImageUrl = v.ImageUrl
                    };

                    var vResult = await Supabase.Client.From<ProductVariant>().Insert(insertVariant);
                    savedVariant = vResult.Models.First();
                    v.Id = savedVariant.Id;
                }
                else
                {
                    var updateVariant = new ProductVariant
                    {
                        Id = v.Id.Value,
                        ProductId = product.Id,
                        SourceId = savedSource.Id,
                        Name = v.Name,
                        OrderIndex = v.OrderIndex,
                        Owned = IsTemplateMode ? 0 : v.Owned,
                        Wanted = v.Wanted,
                        ImageUrl = v.ImageUrl
                    };

                    await Supabase.Client.From<ProductVariant>().Update(updateVariant);
                    savedVariant = updateVariant;
                }

                // キャラ紐付け再 Insert
                await Supabase.Client
                    .From<ProductVariantCharacter>()
                    .Where(x => x.ProductVariantId == savedVariant.Id)
                    .Delete();

                foreach (var charId in v.CharacterIds)
                {
                    await Supabase.Client.From<ProductVariantCharacter>().Insert(
                        new ProductVariantCharacter
                        {
                            ProductVariantId = savedVariant.Id,
                            CharacterId = charId
                        }
                    );
                }
            }

            // Insert/Update が全て終わった後に削除判定
            var existingVariants = await Supabase.Client
                .From<ProductVariant>()
                .Where(x => x.SourceId == savedSource.Id)
                .Get();

            var existingVariantIds = existingVariants.Models.Select(x => x.Id).ToHashSet();
            var currentVariantIds = vm.Variants
                .Where(v => v.Id.HasValue)
                .Select(v => v.Id!.Value)
                .ToHashSet();

            foreach (var delId in existingVariantIds.Except(currentVariantIds))
            {
                await Supabase.Client
                    .From<ProductVariant>()
                    .Where(x => x.Id == delId)
                    .Delete();
            }
        }

        GoBack();
    }


    /// <summary>画像アップロード</summary>
    /// <param name="e"></param>
    /// <param name="variant"></param>
    /// <returns></returns>
    private async Task OnImageSelected(InputFileChangeEventArgs e, ProductVariantViewModel variant)
    {
        var file = e.File;
        if (file == null) return;

        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes = ms.ToArray();

        // ★ 保存前はアップロードしない
        variant.TempImageBytes = bytes;

        // ★ プレビュー用に Base64 URL をセット
        variant.ImageUrl = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
    }

    #endregion 保存
}
