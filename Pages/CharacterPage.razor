@page "/characters/{SeriesId:int}"
@inject SupabaseClientService Supabase
@inject IDialogService Dialog
@inject NavigationManager Nav
@inject IJSRuntime JS

<MudPaper Class="pa-4 mx-auto" MaxWidth="600px" Elevation="4">

    <MudText Typo="Typo.h5" Class="mb-4">キャラ一覧</MudText>

    <MudButton Variant="Variant.Filled"
               Color="MudBlazor.Color.Primary"
               OnClick="AddCharacterDialog">
        ＋ 新規キャラ追加
    </MudButton>

    <div @ref="listRef">
        @foreach (var c in characterList)
        {
            <div class="sortable-item">
                <span class="drag-handle" style="cursor:grab;">☰</span>
                <span>@c.Name</span>

                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           OnClick="@(() => EditCharacterDialog(c))">
                    編集
                </MudButton>

                <MudButton Variant="Variant.Text"
                           Color="Color.Error"
                           OnClick="@(() => DeleteCharacter(c))">
                    削除
                </MudButton>
            </div>
        }
    </div>

    <MudButton Variant="Variant.Text"
               Color="MudBlazor.Color.Secondary"
               Class="mt-4"
               OnClick="@(() => Nav.NavigateTo("series"))">
        ← 作品一覧へ戻る
    </MudButton>

</MudPaper>

@code {
    [Parameter] public int SeriesId { get; set; }

    List<Character> characterList = new();

    ElementReference listRef;
    DotNetObjectReference<CharacterPage>? dotnetRef;

    public class SortEvent
    {
        public int oldIndex { get; set; }
        public int newIndex { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCharacters();
    }

    private async Task LoadCharacters()
    {
        var result = await Supabase.Client
            .From<Character>()
            .Select("*")
            .Filter("series_id", Operator.Equals, SeriesId)
            .Order("order_index", Ordering.Ascending)
            .Get();

        characterList = result.Models;
    }

    private async Task AddCharacterDialog()
    {
        var parameters = new DialogParameters
        {
            { "Character", new Character { SeriesId = SeriesId } }
        };

        var dialog = await Dialog.ShowAsync<Components.CharacterEditDialog>(
            "新規キャラ追加",
            parameters
        );

        var result = await dialog.Result;
        if (!result.Canceled)
            await LoadCharacters();
    }

    private async Task EditCharacterDialog(Character c)
    {
        var parameters = new DialogParameters
        {
            { "Character", c }
        };

        var dialog = await Dialog.ShowAsync<Components.CharacterEditDialog>(
            "キャラ編集",
            parameters
        );

        var result = await dialog.Result;
        if (!result.Canceled)
            await LoadCharacters();
    }

    private async Task DeleteCharacter(Character c)
    {
        bool? confirm = await Dialog.ShowMessageBoxAsync(
            "確認",
            $"{c.Name} を削除しますか？",
            yesText: "削除",
            cancelText: "キャンセル"
        );

        if (confirm == true)
        {
            await Supabase.Client.From<Character>().Delete(c);
            await LoadCharacters();
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("initSortable", listRef, dotnetRef);
        }
    }

    /// <summary>並べ替え</summary>
    [JSInvokable]
    public async Task OnSortChanged(SortEvent evt)
    {
        var item = characterList[evt.oldIndex];
        characterList.RemoveAt(evt.oldIndex);
        characterList.Insert(evt.newIndex, item);

        // order_index 保存
        for (int i = 0; i < characterList.Count; i++)
        {
            characterList[i].OrderIndex = i;
            await Supabase.Client.From<Character>().Upsert(characterList[i]);
        }

        StateHasChanged();
    }
}
