@page "/products/{Id:long}"
@inject SupabaseClientService Supabase

<h3>商品詳細</h3>

@if (product == null)
{
    <p>読み込み中...</p>
}
else
{
    <p><strong>@product.Title</strong></p>
    <p>作品：@product.Series</p>
    <p>カテゴリ：@product.Category</p>
}

@code {
    [Parameter] public Guid Id { get; set; }

    Product? product;

    protected override async Task OnInitializedAsync()
    {
        var result = await Supabase.Client
            .From<Product>()
            .Where(x => x.Id == Id)
            .Get();

        product = result.Models.FirstOrDefault();
    }
}