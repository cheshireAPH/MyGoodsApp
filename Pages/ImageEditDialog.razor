@inject SupabaseClientService Supabase
@inject NavigationManager Nav
@inject IDialogService DialogService

<MudDialog FullScreen="true" DisableDefaultTitle="true">

    <TitleContent>
        <MudPaper Class="cropper-top-bar">
            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudButton Variant="MudBlazor.Variant.Text" OnClick="Close">キャンセル</MudButton>
                <MudText Typo="Typo.h6">画像編集</MudText>
                <MudButton Variant="MudBlazor.Variant.Filled" Color="Color.Primary" OnClick="ApplyCrop">OK</MudButton>
            </MudStack>
        </MudPaper>
    </TitleContent>

    <DialogContent >
        <MudPaper Class="cropper-main">
            <div id="crop-container">
                <img id="edit-image" src="@this.Variant.ImageUrl" onload="cropper.init()" />

                <div id="crop-frame" class="@GetCropFrameClass()">
                    <div class="handle handle-nw"></div>
                    <div class="handle handle-ne"></div>
                    <div class="handle handle-sw"></div>
                    <div class="handle handle-se"></div>
                </div>
            </div>
        </MudPaper>
    </DialogContent>

    <DialogActions >
        <MudPaper Class="cropper-bottom-bar">
            <MudIconButton Icon="@Icons.Material.Filled.RotateRight" OnClick="Rotate90" />
            <MudIconButton Icon="@GetShapeIcon()" OnClick="ToggleShape" />
            @if (CurrentShape == CropShape.Rectangle)
            {
                <MudIconButton Icon="@(AspectLocked? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                               OnClick="ToggleAspectLock" />
            }
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="Reset" />
        </MudPaper>
    </DialogActions>

</MudDialog>