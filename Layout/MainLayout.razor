@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <!-- トップバー -->
    <MudAppBar Color="Color.Primary" Elevation="4">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">Collection</MudText>
    </MudAppBar>

    <!-- サイドメニュー -->
    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Temporary" Elevation="1" Class="drawer-style">
        <MudNavMenu>

            <MudNavLink Href="" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">
                Home
            </MudNavLink>

            <MudNavLink Href="series" Icon="@Icons.Material.Filled.Collections">
                Seriese
            </MudNavLink>

            <MudNavLink Href="templates" Icon="@Icons.Material.Filled.Image">
                Templates
            </MudNavLink>

            <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">
                Settings
            </MudNavLink>

            <MudNavLink Href="products/new" Icon="@Icons.Material.Filled.Add">
                Add Product
            </MudNavLink>

        </MudNavMenu>
    </MudDrawer>

    <!-- メインコンテンツ -->
    <MudMainContent>
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private MudTheme _theme = new CuteTheme();

    bool _drawerOpen = false;
    void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
