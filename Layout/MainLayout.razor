@using MyGoodsApp.Services
@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <!-- トップバー -->
    <MudAppBar Color="Color.Primary" Elevation="4">
        <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="full-width px-2">
            @switch (LayoutState.LeftMode)
            {
                case HeaderLeftMode.Back:
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               OnClick="@LayoutState.OnBack">
                        @LayoutState.BackButtonText
                    </MudButton>
                    break;

                case HeaderLeftMode.Menu:
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                   Color="Color.Inherit"
                                   Edge="Edge.Start"
                                   OnClick="@ToggleDrawer" />
                    break;

                case HeaderLeftMode.None:
                    <div style="width:80px"></div>
                    break;
            }

            <MudText Typo="Typo.h5" Class="ml-2 header-title">
                @LayoutState.PageTitle
            </MudText>

            @if (LayoutState.ShowSaveButton)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@LayoutState.OnSave">
                    @LayoutState.SaveButtonText
                </MudButton>
            }
            else
            {
                <div style="width:80px"></div>
            }

        </MudStack>
    </MudAppBar>

    <!-- サイドメニュー（MenuMode のときだけ表示） -->
    @if (LayoutState.LeftMode == HeaderLeftMode.Menu)
    {
        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="DrawerVariant.Temporary"
                   Elevation="1"
                   Class="drawer-style">

            <MudNavMenu>

                <MudNavLink Href="series" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">
                    Home
                </MudNavLink>

                <MudNavLink Href="seriesPage" Icon="@Icons.Material.Filled.Collections">
                    Seriese
                </MudNavLink>

                <MudNavLink Href="templates" Icon="@Icons.Material.Filled.Image">
                    Templates
                </MudNavLink>

                <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">
                    Settings
                </MudNavLink>

                <MudNavLink Href="products/new" Icon="@Icons.Material.Filled.Add">
                    Add Product
                </MudNavLink>

            </MudNavMenu>

        </MudDrawer>
    }

    <!-- メインコンテンツ -->
    <MudMainContent>
        @Body
    </MudMainContent>

</MudLayout>

@code {
    private MudTheme _theme = new CuteTheme();

    [Inject] public LayoutStateService LayoutState { get; set; } = default!;

    protected override void OnInitialized()
    {
        LayoutState.OnChange += StateHasChanged;

        LayoutState.SetState(
            "Collection",
            default,
            default,
            leftMode: HeaderLeftMode.Menu,
            showSave: false
        );
    }

    bool _drawerOpen = false;
    void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
